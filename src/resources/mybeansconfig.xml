<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
    xmlns:context="http://www.springframework.org/schema/context"
    xsi:schemaLocation="http://www.springframework.org/schema/beans
    http://www.springframework.org/schema/beans/spring-beans.xsd
    http://www.springframework.org/schema/context
    http://www.springframework.org/schema/context/spring-context.xsd">
    
    <bean id="e1" class="com.excelr.model.Engine">
    <constructor-arg value="2000"></constructor-arg>
    <constructor-arg value="2.0"></constructor-arg>
    <constructor-arg value="Honda"></constructor-arg>
    <constructor-arg value="Petrol"></constructor-arg>
    </bean>
    
    <bean id="e2" class="com.excelr.model.Engine">
    <property name="engineCC">
    	<value>2500</value>
    </property>
    
    <property name="engineLiter">
    	<value>2.5</value>
    </property>
    
    <property name="engineMfg">
    	<value>Toyota</value>
    </property>
    
    <property name="engineType">
    	<value>Diesel</value>
    </property>
    </bean>

</beans>